---
# vaultwarden-secrets.sops.yaml.example
#
# Copy this file to vaultwarden-secrets.sops.yaml, replace placeholders
# with real values, then encrypt with SOPS:
#
#   sops --encrypt --in-place clusters/homelab/secrets/vaultwarden-secrets.sops.yaml
#
# THIS FILE IS NOT ENCRYPTED. It is a plain-text template for reference only.
#
# IMPORTANT: Base64-encode every value before pasting it in.
#   echo -n "my-real-admin-token" | base64 -w0
#
# The Deployment uses envFrom.secretRef vaultwarden-secrets, so each key
# becomes an environment variable.  Only ADMIN_TOKEN and DOMAIN are
# truly secret here; non-sensitive defaults are set directly in the
# Deployment manifest.
#
# === Fields ===
# ADMIN_TOKEN       — Hash of the admin panel password (or raw password).
#                     Generate with: echo -n "your-admin-password" | argon2 12 3 32
#                     Or use a raw token: openssl rand -base64 48
# DOMAIN            — Public-facing URL (Tailscale or proxy endpoint).
#                     Example: https://vaultwarden.tail-abc123.ts.net
# SIGNUPS_ALLOWED   — (optional, override if needed)
# INVITATIONS_ALLOWED — (optional, override if needed)
# WEBSOCKET_ENABLED — (optional, override if needed)
# ROCKET_PORT       — (optional, override if needed)
# DATA_FOLDER       — (optional, override if needed)
# SMTP_*            — (optional, uncomment and fill when email is configured)
apiVersion: v1
kind: Secret
metadata:
  name: vaultwarden-secrets
  namespace: vaultwarden
type: Opaque
data:
  # FAKE placeholder — replace with real base64-encoded values.
  ADMIN_TOKEN: "JDJhJDEyJEVYQU1QTEVfQVJHT04yX0hBU0hfUExBQ0VIT0xERVI="
  DOMAIN: "aHR0cHM6Ly92YXVsdHdhcmRlbi50YWlsLWFhYWFiY2MuYnMubmV0"
  # Non-sensitive defaults are set in the Deployment manifest.
  # Override them here only if you need per-environment values.
  # SIGNUPS_ALLOWED: "ZmFsc2U="
  # INVITATIONS_ALLOWED: "ZmFsc2U="
  # WEBSOCKET_ENABLED: "dHJ1ZQ=="
  # ROCKET_PORT: "ODA="
  # DATA_FOLDER: "L2RhdGE="
  # --- SMTP (uncomment and fill when email is configured) ---
  # SMTP_HOST: "c210cC5leGFtcGxlLmNvbQ=="
  # SMTP_PORT: "NTg3"
  # SMTP_SECURITY: "c3RhcnR0bHM="
  # SMTP_USERNAME: "dmF1bHRAdmF1bHR3YXJkZW4uZXhhbXBsZQ=="
  # SMTP_PASSWORD: "c210cF9wYXNzd29yZF9wbGFjZWhvbGRlcg=="
  # SMTP_FROM: "dmF1bHRAdmF1bHR3YXJkZW4uZXhhbXBsZQ=="
