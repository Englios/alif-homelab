---
# tailscale-operator-auth.sops.yaml.example
#
# Copy this file to tailscale-operator-auth.sops.yaml, replace the placeholder
# with a real Tailscale auth key, then encrypt with SOPS:
#
#   sops --encrypt --in-place clusters/homelab/secrets/tailscale-operator-auth.sops.yaml
#
# THIS FILE IS NOT ENCRYPTED. It is a plain-text template for reference only.
#
# === Where to get the key ===
# Tailscale admin console → Settings → Keys → Generate auth key with:
#   - Reusable: ON
#   - Ephemeral: OFF
#   - Pre-approved: ON
#   - Tags: tag:k8s
#   - Expiration: 90 days
#
# === IMPORTANT ===
# Base64-encode the value before pasting it in:
#   echo -n "tskey-auth-..." | base64 -w0
#
# The Tailscale Kubernetes Operator reads this Secret's TS_AUTH_KEY field as
# an env var at startup. The operator lives in the `tailscale` namespace.
apiVersion: v1
kind: Secret
metadata:
  name: tailscale-operator-auth
  namespace: tailscale
type: Opaque
data:
  # FAKE placeholder — replace with real base64-encoded Tailscale auth key.
  TS_AUTH_KEY: "dHNrZXktYXV0aC1GQUtFX1BMSUNFSE9MREVSX1ZBTFVFX0hFUkU="
