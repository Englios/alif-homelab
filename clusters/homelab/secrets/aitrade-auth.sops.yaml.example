---
# aitrade-auth.sops.yaml.example
#
# Copy this file to aitrade-auth.sops.yaml, replace the placeholder deploy
# key / token with a real one from GitHub, then encrypt with SOPS:
#
#   sops --encrypt --in-place clusters/homelab/secrets/aitrade-auth.sops.yaml
#
# THIS FILE IS NOT ENCRYPTED. It is a plain-text template for reference only.
# The actual secret file (*.sops.yaml) is encrypted and excluded from
# accidental commit only when properly encrypted (the .gitignore allows
# *.sops.yaml through).
#
# The deploy key (or fine-grained token) must have read access to the
# https://github.com/Englios/ai-trade repository.
#
# IMPORTANT: These are FAKE placeholder values. Do not use them.
apiVersion: v1
kind: Secret
metadata:
  name: aitrade-auth
  namespace: flux-system
type: Opaque
data:
  # Replace with the base64-encoded deploy key (or token).
  # For an SSH deploy key:
  #   base64 -w0 ~/.ssh/aitrade-deploykey
  # For a fine-grained token:
  #   echo -n "ghp_FIXME_REPLACE_ME" | base64 -w0
  #
  # FAKE placeholder — DO NOT USE:
  identity: "c3NoLXJzYSBGRUtFIFBMQUNFSE9MREVS..."
  # For token-based auth, use "password" instead:
  # password: "Z2hwX0ZJWEdVWUZBS0VUT0tFTg=="
